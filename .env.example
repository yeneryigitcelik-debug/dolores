# ---- Postgres ----
POSTGRES_USER=dolores
POSTGRES_PASSWORD=dolores
POSTGRES_DB=dolores
POSTGRES_PORT=5433
# Admin/migration connection (superuser — runs migrations, bypasses RLS)
DATABASE_URL=postgresql://dolores:dolores@localhost:5433/dolores
# App connection (non-superuser dolores_app — daemon connects with this so RLS
# IS enforced; superusers bypass RLS even under FORCE ROW LEVEL SECURITY)
DOLORES_APP_DATABASE_URL=postgresql://dolores_app:dolores@localhost:5433/dolores
# Password set on the dolores_app role by applyMigrations(). Change in production.
DOLORES_APP_PASSWORD=dolores

# ---- Daemon ----
DOLORES_DAEMON_HOST=127.0.0.1
DOLORES_DAEMON_PORT=4505
# DOLORES_AUTH_TOKEN=         # Required when DOLORES_DAEMON_HOST is not localhost/127.0.0.1.
#                             # If unset on a non-localhost bind, the daemon refuses to start.
#                             # CLI/MCP callers must send: Authorization: Bearer <token>

# ---- Identity (default tenant for CLI + MCP) ----
# workspaceId is required for every memory op (RLS isolation key). For local
# single-user use this fixed default workspace is fine; teams set their own UUID.
DOLORES_WORKSPACE_ID=00000000-0000-0000-0000-000000000001
# DOLORES_USER_ID=        # optional; empty = workspace-level memories only

# ---- Embedding: local | openai | noop ----
# local  = free, CPU, fastembed bge-small (default, 384 dims)
# openai = requires OPENAI_API_KEY
# noop   = no embeddings, Postgres full-text only ("lite mode")
DOLORES_EMBEDDER=local
DOLORES_EMBED_MODEL=bge-small-en-v1.5
# OPENAI_API_KEY=sk-...

# ---- Extraction (optional, async, cheap model) ----
# Kept off the critical path. Uses your existing LLM subscription / API key.
DOLORES_EXTRACTION_ENABLED=false
# Provider: anthropic | openai. If unset, auto-selects: ANTHROPIC_API_KEY first
# (Claude subscription), else OPENAI_API_KEY; neither key → extraction disabled.
# DOLORES_EXTRACTION_PROVIDER=anthropic
# Override the chosen provider's cheap default model
# (anthropic → claude-haiku-4-5-20251001, openai → gpt-4o-mini).
# DOLORES_EXTRACTION_MODEL=claude-haiku-4-5-20251001
# Drop extracted items whose model-reported confidence is below this (0..1).
# 0 (default) keeps everything; items without a confidence are always kept.
# DOLORES_EXTRACTION_MIN_CONFIDENCE=0
# ANTHROPIC_API_KEY=...    # needs the optional @anthropic-ai/sdk package
# OPENAI_API_KEY=sk-...    # needs the optional openai package

# ---- Decay policy ----
# conservative (default) = only soften importance over time, never auto-delete
# aggressive             = pg_cron deletes old, unused, low-importance memories
DOLORES_DECAY_MODE=conservative

# ---- Memory evolution (EPIC F) ----
# How a near-duplicate write (cosine > 0.9) is handled:
# inplace (default) = overwrite the existing memory; no history, least storage.
# versioned         = insert a fresh active row and mark the old one superseded,
#                     keeping history so point-in-time recall works:
#                       dolores recall "hosting"               → current value
#                       recall with asOf=<past timestamp>      → value as of then
DOLORES_EVOLUTION_MODE=inplace

# ---- Retrieval ranking (EPIC H) ----
# Vector index access method (EPIC I): ivfflat (default) or hnsw (pgvector >=0.5).
# hnsw = higher recall + lower latency at scale, slower build, more memory.
# Changing this rebuilds the index on next `dolores init` / daemon start.
# DOLORES_VECTOR_INDEX=ivfflat
# ivfflat probes: higher = better recall, slower (index built with lists=100).
# DOLORES_IVFFLAT_PROBES=10
# hnsw.ef_search: higher = better recall, slower (only used when index=hnsw).
# DOLORES_HNSW_EF_SEARCH=40
# RRF arm weights: bias the hybrid score toward vector or full-text (default 1=1).
# DOLORES_FUSION_VECTOR_WEIGHT=1
# DOLORES_FUSION_FT_WEIGHT=1
# MMR diversity λ: 1 (default) = pure relevance (off); <1 trades relevance for
# diversity so the top-N isn't near-duplicate memories (e.g. 0.7). Pure math,
# no model — stays off the LLM-free recall path.
# DOLORES_MMR_LAMBDA=1
# Final-stage reranker: 'noop' (default, identity) is the only kind today. The
# Reranker interface is the extension point for a LOCAL cross-encoder (never an
# LLM); unknown values fall back to noop.
# DOLORES_RERANKER=noop
