{
  "name": "dolores",
  "version": "0.1.0",
  "private": true,
  "description": "Postgres-backed agent memory — self-hosted, free local embeddings, KVKK-clean.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "test": "pnpm -r test",
    "lint": "biome check .",
    "format": "biome format --write .",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f db",
    "bench": "DOLORES_MODEL_CACHE=packages/core/.dolores-models node_modules/.bin/tsx benchmarks/run.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild",
      "onnxruntime-node"
    ]
  }
}
